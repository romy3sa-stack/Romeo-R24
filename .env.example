# Public client configuration. Use the publishable/anon key only in clients.
APP_ENV=development
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Server-only configuration. Never expose these values to a client bundle.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_JWT_SECRET=

# Provider integrations are intentionally unconfigured in Phase 1-2.
OCR_PROVIDER=
OCR_API_KEY=
EMAIL_PROVIDER=
EMAIL_API_KEY=
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
PAYMENT_PROVIDER=
PAYMENT_SECRET_KEY=
ANALYTICS_PROVIDER=
ANALYTICS_API_KEY=
