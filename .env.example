# Public client configuration (safe to expose in a client application)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server and Edge Function configuration only. Never expose these in a client.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# External service credentials for server-side use only
OCR_PROVIDER=
OCR_API_KEY=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FCM_SERVICE_ACCOUNT_JSON=
POSTHOG_API_KEY=

# Local environment selection
APP_ENV=development
