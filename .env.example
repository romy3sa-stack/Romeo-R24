# =============================================================================
# Receipt24 Environment Variables
# Copy to .env and fill in values. NEVER commit real secrets.
# =============================================================================

# --- Supabase (public keys safe for frontend) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-side only — never expose in frontend) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# --- Application URLs ---
APP_URL=https://app.receipt24.com
ACCOUNTANT_PORTAL_URL=https://accountant.receipt24.com
ADMIN_DASHBOARD_URL=https://admin.receipt24.com
API_URL=https://api.receipt24.com

# --- Email (Resend / SendGrid) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@receipt24.com
EMAIL_RECEIPTS_DOMAIN=receipts.receipt24.com

# --- OCR Provider ---
OCR_PROVIDER=google_vision
GOOGLE_VISION_API_KEY=your-google-vision-key
# AWS_TEXTRACT_ACCESS_KEY=
# AWS_TEXTRACT_SECRET_KEY=
# AWS_TEXTRACT_REGION=

# --- Payments (Stripe) ---
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Push Notifications (Firebase) ---
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./secrets/firebase-service-account.json

# --- Analytics ---
POSTHOG_API_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# --- Environment ---
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=debug

# --- Security ---
RATE_LIMIT_REQUESTS_PER_MINUTE=60
SESSION_EXPIRY_HOURS=24
SIGNED_URL_EXPIRY_SECONDS=3600
