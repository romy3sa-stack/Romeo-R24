# Receipt24 environment template
# Copy to .env.development / .env.testing / .env.production as needed.
# NEVER commit real secrets. NEVER expose service-role keys in frontend apps.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
APP_NAME=Receipt24
APP_TAGLINE=Every Receipt. One Place.
CONSUMER_APP_URL=http://localhost:3000
ACCOUNTANT_PORTAL_URL=http://localhost:3001
ADMIN_DASHBOARD_URL=http://localhost:3002
API_URL=http://localhost:54321
EMAIL_FORWARDING_DOMAIN=receipts.receipt24.com

# ---------------------------------------------------------------------------
# Supabase (public / frontend-safe)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key

# Supabase (server only — Edge Functions / backend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ---------------------------------------------------------------------------
# Auth providers (optional for local)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@receipt24.com

# ---------------------------------------------------------------------------
# OCR (server only)
# ---------------------------------------------------------------------------
OCR_PROVIDER=google_vision
GOOGLE_VISION_API_KEY=
AWS_TEXTRACT_ACCESS_KEY=
AWS_TEXTRACT_SECRET_KEY=
MINDEE_API_KEY=

# ---------------------------------------------------------------------------
# Payments (server only)
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
PAYSTACK_SECRET_KEY=
PEACH_PAYMENTS_SECRET=

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
FCM_SERVER_KEY=
FCM_PROJECT_ID=
SMS_PROVIDER=
SMS_API_KEY=

# ---------------------------------------------------------------------------
# Analytics
# ---------------------------------------------------------------------------
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
FIREBASE_ANALYTICS_ID=
